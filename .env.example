# Variables de Entorno — PlanX System v2.0
# Copiar este archivo como .env y completar los valores

# === Google Gemini API ===
VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL_PRIMARY=gemini-2.5-flash
VITE_GEMINI_MODEL_FALLBACK=gemini-2.0-flash
VITE_GEMINI_MODEL_LAST_RESORT=gemini-1.5-flash-latest

# === LM Studio (Desarrollo Local) ===
VITE_LMSTUDIO_URL=http://localhost:1234/v1/chat/completions

# === Supabase ===
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# === CNEB ===
VITE_CNEB_INDEX_VERSION=2026.02.14.v1

# === Fechas por Defecto ===
VITE_DEFAULT_START_DATE=2026-03-02
VITE_DEFAULT_END_DATE=2026-04-03
